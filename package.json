{
  "name": "epde",
  "private": true,
  "scripts": {
    "dev": "turbo dev --filter=!@epde/mobile",
    "dev:mobile": "turbo build --filter=@epde/shared && pnpm --filter @epde/mobile dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "prepare": "husky",
    "db:push": "pnpm --filter @epde/api exec prisma db push",
    "db:migrate": "pnpm --filter @epde/api exec prisma migrate dev",
    "db:seed": "pnpm --filter @epde/api exec prisma db seed",
    "db:studio": "pnpm --filter @epde/api exec prisma studio",
    "db:generate": "pnpm --filter @epde/api exec prisma generate",
    "check:schema-drift": "node scripts/check-schema-drift.mjs",
    "check:docs-drift": "node scripts/check-docs-drift.mjs"
  },
  "devDependencies": {
    "@commitlint/cli": "^19",
    "@commitlint/config-conventional": "^19",
    "@eslint/js": "^9",
    "@typescript-eslint/eslint-plugin": "^8",
    "@typescript-eslint/parser": "^8",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9",
    "lint-staged": "^15",
    "prettier": "^3.5",
    "prettier-plugin-tailwindcss": "^0.6",
    "turbo": "^2",
    "typescript": "^5.7"
  },
  "packageManager": "pnpm@10.6.1",
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "lightningcss": "1.30.1",
      "axios": "^1.15.0",
      "fast-xml-parser": "^5.3.8",
      "handlebars": "^4.7.9"
    },
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma",
      "sharp",
      "unrs-resolver"
    ]
  }
}
