# Database (add &connection_limit=20 for production — default Prisma pool is too small for concurrent load)
DATABASE_URL="postgresql://epde:epde_dev_password@localhost:5433/epde?schema=public&connection_limit=5"

# Auth
# JWT_SECRET MUST be a strong random value (≥32 chars, never a placeholder).
# Generate locally with: openssl rand -hex 32
# The Zod validator in apps/api/src/config/config.module.ts hard-fails startup
# if JWT_SECRET matches a known placeholder string (including this one).
# Rotation procedure for prod env vars: see SECURITY.md.
JWT_SECRET="REPLACE_ME_run_openssl_rand_hex_32"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Redis
REDIS_URL="redis://localhost:6379"

# App
NODE_ENV="development"
API_PORT=3001
WEB_PORT=3000

# Frontend
FRONTEND_URL="http://localhost:3000"

# Resend (email)
RESEND_API_KEY="re_your_api_key"

# Sentry
SENTRY_DSN=""

# Cookie settings
# With Next.js proxy (rewrites), use 'strict' (browser sees same origin)
# Only use 'none' if web and API are on different domains WITHOUT a proxy
COOKIE_SAME_SITE="strict"

# CORS — required in production/staging
# Comma-separated origins allowed
CORS_ORIGIN="http://localhost:3000"

# Seed (optional — warns if using default)
SEED_ADMIN_PASSWORD=""

# Cloudflare R2 (storage)
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="epde"
R2_PUBLIC_URL=""
