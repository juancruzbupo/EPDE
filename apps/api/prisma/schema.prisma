generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pg_trgm]
}

// ─── Enums ───────────────────────────────────────────────

enum UserRole {
  CLIENT
  ADMIN
}

enum UserStatus {
  INVITED
  ACTIVE
  INACTIVE
}

enum PropertyType {
  HOUSE
  APARTMENT
  DUPLEX
  COUNTRY_HOUSE
  OTHER
}

enum PlanStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum RecurrenceType {
  MONTHLY
  QUARTERLY
  BIANNUAL
  ANNUAL
  CUSTOM
  ON_DETECTION
}

enum TaskStatus {
  PENDING
  UPCOMING
  OVERDUE
  COMPLETED
}

enum BudgetStatus {
  PENDING
  QUOTED
  APPROVED
  REJECTED
  IN_PROGRESS
  COMPLETED
  EXPIRED
}

enum ServiceUrgency {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ServiceStatus {
  OPEN
  IN_REVIEW
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum NotificationType {
  TASK_REMINDER
  BUDGET_UPDATE
  SERVICE_UPDATE
  SYSTEM
}

enum TaskType {
  INSPECTION
  CLEANING
  TEST
  TREATMENT
  SEALING
  LUBRICATION
  ADJUSTMENT
  MEASUREMENT
  EVALUATION
}

enum ProfessionalRequirement {
  OWNER_CAN_DO
  PROFESSIONAL_RECOMMENDED
  PROFESSIONAL_REQUIRED
}

enum TaskResult {
  OK
  OK_WITH_OBSERVATIONS
  NEEDS_ATTENTION
  NEEDS_REPAIR
  NEEDS_URGENT_REPAIR
  NOT_APPLICABLE
}

enum ConditionFound {
  EXCELLENT
  GOOD
  FAIR
  POOR
  CRITICAL
}

enum TaskExecutor {
  OWNER
  HIRED_PROFESSIONAL
  EPDE_PROFESSIONAL
}

enum ActionTaken {
  INSPECTION_ONLY
  CLEANING
  MINOR_REPAIR
  MAJOR_REPAIR
  REPLACEMENT
  TREATMENT
  SEALING
  ADJUSTMENT
  FULL_SERVICE
  NO_ACTION
}

enum PropertySector {
  EXTERIOR
  ROOF
  TERRACE
  INTERIOR
  KITCHEN
  BATHROOM
  BASEMENT
  GARDEN
  INSTALLATIONS
}

// ─── Models ──────────────────────────────────────────────

model User {
  id                    String     @id @default(uuid())
  email                 String     @unique @db.VarChar(254)
  passwordHash          String?
  name                  String     @db.VarChar(200)
  phone                 String?    @db.VarChar(30)
  role                  UserRole   @default(CLIENT)
  status                UserStatus @default(INVITED)
  lastLoginAt           DateTime?
  activatedAt           DateTime?
  subscriptionExpiresAt DateTime?
  streakFreezeUsedAt    DateTime?
  isvGoal               Int?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  deletedAt             DateTime?

  /// Referral program — "Trae un amigo". See ADR-010.
  /// Nullable until every existing user is backfilled (see prisma/seed.ts).
  /// New users always get a code assigned in UserService.create.
  referralCode                    String? @unique @db.VarChar(20)
  referredByCode                  String? @db.VarChar(20) /// Code of the referrer at signup, historical.
  referralCount                   Int     @default(0) /// Total referrals registered (any status).
  convertedCount                  Int     @default(0) /// Referrals that actually paid (cap at 10 for rewards).
  referralCreditMonths            Int     @default(0) /// Absolute months of credit earned at current milestone.
  referralCreditAnnualDiagnosis   Int     @default(0) /// 0 or 1 — earned at milestone 3.
  referralCreditBiannualDiagnosis Int     @default(0) /// 0 or 1 — earned at milestone 10 (program cap).

  properties              Property[]
  taskLogs                TaskLog[]
  taskNotes               TaskNote[]
  taskAuditLogs           TaskAuditLog[]
  budgetRequests          BudgetRequest[]
  budgetAuditLogs         BudgetAuditLog[]         @relation("BudgetAuditLogs")
  budgetComments          BudgetComment[]          @relation("BudgetComments")
  serviceRequests         ServiceRequest[]
  serviceRequestAuditLogs ServiceRequestAuditLog[] @relation("ServiceRequestAuditLogs")
  serviceRequestComments  ServiceRequestComment[]  @relation("ServiceRequestComments")
  notifications           Notification[]
  authAuditLogs           AuthAuditLog[]
  quoteTemplates          QuoteTemplate[]          @relation("QuoteTemplateCreator")
  pushTokens              PushToken[]
  inspections             InspectionChecklist[]
  milestones              UserMilestone[]
  weeklyChallenges        WeeklyChallenge[]
  referralsMade           Referral[]               @relation("ReferralsMade")
  referralsReceived       Referral[]               @relation("ReferralsReceived")
  technicalInspections    TechnicalInspection[]

  @@index([email])
  @@index([role, deletedAt])
  @@index([status, subscriptionExpiresAt])
  @@index([role, status, deletedAt])
}

model Property {
  id              String           @id @default(uuid())
  userId          String
  createdBy       String?
  updatedBy       String?
  address         String           @db.VarChar(500)
  city            String           @db.VarChar(200)
  type            PropertyType     @default(HOUSE)
  activeSectors   PropertySector[] @default([EXTERIOR, ROOF, TERRACE, INTERIOR, KITCHEN, BATHROOM, BASEMENT, GARDEN, INSTALLATIONS])
  yearBuilt       Int?
  squareMeters    Float?
  photoUrl        String?
  /// Last time the admin contacted the client about this property (via WhatsApp button).
  /// Used by the admin tasks dashboard to show cooldown and avoid spamming.
  lastContactedAt DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  deletedAt       DateTime?

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Restrict)
  maintenancePlan      MaintenancePlan?
  budgetRequests       BudgetRequest[]
  serviceRequests      ServiceRequest[]
  isvSnapshots         ISVSnapshot[]
  inspections          InspectionChecklist[]
  technicalInspections TechnicalInspection[]
  certificateEmissions CertificateEmission[]

  @@index([userId])
  @@index([userId, deletedAt])
  @@index([address(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([city(ops: raw("gin_trgm_ops"))], type: Gin)
}

/// No soft-delete: plans are archived (ACTIVE→ARCHIVED), never deleted.
/// Property soft-delete does not cascade to plan — plan persists for audit trail.
model MaintenancePlan {
  id         String     @id @default(uuid())
  propertyId String     @unique
  name       String     @db.VarChar(200)
  status     PlanStatus @default(DRAFT)
  createdBy  String?
  updatedBy  String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  sourceInspectionId String?

  /// Tier de superficie al crear el plan (SMALL/MEDIUM/LARGE).
  /// Nullable: planes pre-tiering (abril 2026) quedan sin tier asignado
  /// y se excluyen del launch tracking.
  priceTier InspectionPriceTier?

  /// Monto efectivamente cobrado al crear el plan (snapshot congelado).
  /// Pensado para revenue tracking del dashboard admin sin tocar el precio
  /// vigente. Null para planes anteriores al tiering (abril 2026).
  priceAmount Decimal? @db.Decimal(12, 2)

  // Restrict: Properties use soft-delete, never hard-deleted. Restrict prevents accidental cascade.
  property Property @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  tasks    Task[]

  @@index([status])
  @@index([createdBy])
  @@index([sourceInspectionId])
  @@index([priceTier, createdAt])
}

model Category {
  id                 String    @id @default(uuid())
  name               String    @db.VarChar(100)
  description        String?   @db.VarChar(500)
  icon               String?   @db.VarChar(50)
  order              Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?
  categoryTemplateId String?

  tasks            Task[]
  categoryTemplate CategoryTemplate? @relation(fields: [categoryTemplateId], references: [id], onDelete: SetNull)

  // PostgreSQL unique: (name, null) = (name, null) prevents duplicate active categories.
  // Soft-deleted categories (deletedAt != null) are each treated as distinct.
  @@unique([name, deletedAt])
  @@index([deletedAt])
  @@index([categoryTemplateId])
}

model Task {
  id                       String                  @id @default(uuid())
  maintenancePlanId        String
  categoryId               String
  sector                   PropertySector?
  name                     String                  @db.VarChar(200)
  description              String?                 @db.VarChar(2000)
  priority                 TaskPriority            @default(MEDIUM)
  recurrenceType           RecurrenceType          @default(ANNUAL)
  recurrenceMonths         Int?
  nextDueDate              DateTime?
  order                    Int                     @default(0)
  status                   TaskStatus              @default(PENDING)
  createdBy                String?
  updatedBy                String?
  taskType                 TaskType                @default(INSPECTION)
  professionalRequirement  ProfessionalRequirement @default(OWNER_CAN_DO)
  assignedToName           String?                 @db.VarChar(200) /// Dormant — not used in UI. Future: replace with assignedToId FK.
  technicalDescription     String?                 @db.VarChar(1000)
  estimatedDurationMinutes Int?
  inspectionFinding        String?                 @db.VarChar(2000)
  inspectionPhotoUrl       String?
  riskScore                Int                     @default(0)
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt
  deletedAt                DateTime?

  // Cascade: Plans are 1:1 with properties; deleting a plan removes all its tasks.
  maintenancePlan MaintenancePlan  @relation(fields: [maintenancePlanId], references: [id], onDelete: Cascade)
  category        Category         @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  taskLogs        TaskLog[]
  taskNotes       TaskNote[]
  auditLogs       TaskAuditLog[]
  serviceRequests ServiceRequest[]
  inspectionItems InspectionItem[]

  @@index([maintenancePlanId])
  @@index([maintenancePlanId, status])
  @@index([status, nextDueDate])
  @@index([status, deletedAt])
  @@index([categoryId])
  @@index([sector])
  @@index([maintenancePlanId, sector])
  @@index([nextDueDate, status])
  @@index([maintenancePlanId, deletedAt, status])
  @@index([riskScore])
}

model TaskLog {
  id             String         @id @default(uuid())
  taskId         String
  completedAt    DateTime       @default(now())
  completedBy    String
  result         TaskResult
  conditionFound ConditionFound
  executor       TaskExecutor
  actionTaken    ActionTaken
  cost           Decimal?       @db.Decimal(12, 2)
  notes          String?        @db.VarChar(2000)
  photoUrl       String?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [completedBy], references: [id], onDelete: Restrict)

  @@index([taskId])
  @@index([taskId, completedAt])
  @@index([completedAt])
  @@index([completedBy, completedAt])
  @@index([conditionFound, taskId]) // getOpenProblems: POOR/CRITICAL filter + taskId join
  @@index([cost, completedAt]) // getPropertyExpenses: cost filter + date sort
}

model TaskNote {
  id        String   @id @default(uuid())
  taskId    String
  authorId  String
  content   String   @db.VarChar(2000)
  createdAt DateTime @default(now())

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Restrict)

  @@index([taskId])
  @@index([authorId])
}

model TaskAuditLog {
  id        String   @id @default(uuid())
  taskId    String
  userId    String
  action    String   @db.VarChar(50)
  before    Json
  after     Json
  changedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([taskId, changedAt])
  @@index([userId, changedAt])
}

model BudgetRequest {
  id          String       @id @default(uuid())
  propertyId  String
  requestedBy String
  title       String       @db.VarChar(200)
  description String?      @db.VarChar(2000)
  status      BudgetStatus @default(PENDING)
  createdBy   String?
  updatedBy   String?
  version     Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  deletedAt   DateTime?

  property    Property           @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  requester   User               @relation(fields: [requestedBy], references: [id], onDelete: Restrict)
  lineItems   BudgetLineItem[]
  response    BudgetResponse?
  auditLogs   BudgetAuditLog[]
  comments    BudgetComment[]
  attachments BudgetAttachment[]

  @@index([propertyId])
  @@index([propertyId, deletedAt])
  @@index([requestedBy, status])
  @@index([status])
  @@index([status, createdAt])
  @@index([status, deletedAt])
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
}

model BudgetLineItem {
  id              String  @id @default(uuid())
  budgetRequestId String
  description     String  @db.VarChar(500)
  quantity        Decimal @db.Decimal(12, 4)
  unitPrice       Decimal @db.Decimal(12, 2)
  subtotal        Decimal @db.Decimal(14, 2)

  budgetRequest BudgetRequest @relation(fields: [budgetRequestId], references: [id], onDelete: Cascade)

  @@index([budgetRequestId])
}

model BudgetResponse {
  id              String    @id @default(uuid())
  budgetRequestId String    @unique
  totalAmount     Decimal   @db.Decimal(14, 2)
  estimatedDays   Int?
  notes           String?   @db.VarChar(2000)
  validUntil      DateTime?
  respondedAt     DateTime  @default(now())

  budgetRequest BudgetRequest @relation(fields: [budgetRequestId], references: [id], onDelete: Cascade)

  @@index([respondedAt]) // getPropertyExpenses: date sort on budget responses
}

model BudgetAuditLog {
  id        String   @id @default(uuid())
  budgetId  String
  userId    String
  action    String   @db.VarChar(50)
  before    Json
  after     Json
  changedAt DateTime @default(now())

  budget BudgetRequest @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  user   User          @relation("BudgetAuditLogs", fields: [userId], references: [id], onDelete: Restrict)

  @@index([budgetId, changedAt])
  @@index([userId, changedAt])
}

model BudgetComment {
  id        String   @id @default(uuid())
  budgetId  String
  userId    String
  content   String   @db.VarChar(2000)
  createdAt DateTime @default(now())

  budget BudgetRequest @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  user   User          @relation("BudgetComments", fields: [userId], references: [id], onDelete: Restrict)

  @@index([budgetId, createdAt])
}

model BudgetAttachment {
  id        String   @id @default(uuid())
  budgetId  String
  url       String
  fileName  String   @db.VarChar(255)
  createdAt DateTime @default(now())

  budget BudgetRequest @relation(fields: [budgetId], references: [id], onDelete: Cascade)

  @@index([budgetId])
}

model ServiceRequest {
  id              String         @id @default(uuid())
  propertyId      String
  requestedBy     String
  taskId          String?
  title           String         @db.VarChar(200)
  description     String         @db.VarChar(2000)
  urgency         ServiceUrgency @default(MEDIUM)
  status          ServiceStatus  @default(OPEN)
  assignedToName  String?        @db.VarChar(200) /// Dormant — not used in UI. Future: replace with assignedToId FK.
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  createdBy       String?
  updatedBy       String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  deletedAt       DateTime?

  property    Property                   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  requester   User                       @relation(fields: [requestedBy], references: [id], onDelete: Restrict)
  task        Task?                      @relation(fields: [taskId], references: [id], onDelete: SetNull)
  photos      ServiceRequestPhoto[]
  auditLogs   ServiceRequestAuditLog[]
  comments    ServiceRequestComment[]
  attachments ServiceRequestAttachment[]
  assignment  ServiceRequestAssignment?

  @@index([propertyId])
  @@index([propertyId, deletedAt])
  @@index([requestedBy, status])
  @@index([status])
  @@index([status, urgency])
  @@index([taskId])
  @@index([status, deletedAt])
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
}

model ServiceRequestPhoto {
  id               String   @id @default(uuid())
  serviceRequestId String
  url              String
  createdAt        DateTime @default(now())

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  @@index([serviceRequestId])
}

model ServiceRequestAuditLog {
  id               String   @id @default(uuid())
  serviceRequestId String
  userId           String
  action           String   @db.VarChar(50)
  before           Json
  after            Json
  changedAt        DateTime @default(now())

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  user           User           @relation("ServiceRequestAuditLogs", fields: [userId], references: [id], onDelete: Restrict)

  @@index([serviceRequestId, changedAt])
  @@index([userId, changedAt])
}

model ServiceRequestComment {
  id               String   @id @default(uuid())
  serviceRequestId String
  userId           String
  content          String   @db.VarChar(2000)
  createdAt        DateTime @default(now())

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  user           User           @relation("ServiceRequestComments", fields: [userId], references: [id], onDelete: Restrict)

  @@index([serviceRequestId, createdAt])
}

model ServiceRequestAttachment {
  id               String   @id @default(uuid())
  serviceRequestId String
  url              String
  fileName         String   @db.VarChar(255)
  createdAt        DateTime @default(now())

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)

  @@index([serviceRequestId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String           @db.VarChar(200)
  message   String           @db.VarChar(2000)
  read      Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, type, createdAt])
  @@index([type, createdAt])
  @@index([createdAt])
}

// ─── Template Models (Master catalog) ───────────────────

model CategoryTemplate {
  id           String         @id @default(uuid())
  name         String         @db.VarChar(100)
  icon         String?        @db.VarChar(10)
  description  String?        @db.VarChar(500)
  displayOrder Int            @default(0)
  tasks        TaskTemplate[]
  categories   Category[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@index([createdAt])
}

model TaskTemplate {
  id                       String                  @id @default(uuid())
  name                     String                  @db.VarChar(200)
  taskType                 TaskType
  professionalRequirement  ProfessionalRequirement @default(OWNER_CAN_DO)
  technicalDescription     String?                 @db.VarChar(1000)
  priority                 TaskPriority            @default(MEDIUM)
  recurrenceType           RecurrenceType
  recurrenceMonths         Int                     @default(12)
  estimatedDurationMinutes Int?
  defaultSector            PropertySector?
  inspectionGuide          String?                 @db.Text
  guideImageUrls           String[]                @default([])
  displayOrder             Int                     @default(0)
  categoryId               String
  category                 CategoryTemplate        @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  createdAt                DateTime                @default(now())
  updatedAt                DateTime                @updatedAt

  @@index([categoryId])
  @@index([categoryId, displayOrder])
}

model QuoteTemplate {
  id        String              @id @default(uuid())
  name      String              @db.VarChar(200)
  createdBy String
  items     QuoteTemplateItem[]
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  creator User @relation("QuoteTemplateCreator", fields: [createdBy], references: [id], onDelete: Restrict)

  @@index([createdBy])
}

model QuoteTemplateItem {
  id           String  @id @default(uuid())
  templateId   String
  description  String  @db.VarChar(500)
  quantity     Decimal @db.Decimal(12, 4)
  unitPrice    Decimal @db.Decimal(12, 2)
  displayOrder Int     @default(0)

  template QuoteTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model AuthAuditLog {
  id         String   @id @default(uuid())
  event      String   @db.VarChar(50)
  userId     String?
  email      String?
  ip         String?
  clientType String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([event, createdAt])
}

model PushToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique @db.VarChar(500)
  platform  String   @db.VarChar(10) // 'ios' | 'android' | 'web'
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

/**
 * Monthly property health snapshots. Retention: 24 months per property (enforced by cleanup scheduler).
 */
model ISVSnapshot {
  id           String   @id @default(uuid())
  propertyId   String
  snapshotDate DateTime
  score        Int
  label        String   @db.VarChar(50)
  compliance   Int
  condition    Int
  coverage     Int
  investment   Int
  trend        Int
  sectorScores Json
  createdAt    DateTime @default(now())

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, snapshotDate])
  @@index([propertyId])
  @@index([propertyId, snapshotDate(sort: Desc)])
}

// ─── Inspection Checklists ────────────────────────────────

enum InspectionItemStatus {
  PENDING
  OK
  NEEDS_ATTENTION
  NEEDS_PROFESSIONAL
}

enum InspectionChecklistStatus {
  DRAFT /// Still being filled in or ready to generate a plan.
  COMPLETED /// Plan already generated from this checklist; items are read-only.
}

model InspectionChecklist {
  id          String                    @id @default(uuid())
  propertyId  String
  property    Property                  @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  inspectedBy String
  inspector   User                      @relation(fields: [inspectedBy], references: [id])
  inspectedAt DateTime                  @default(now())
  notes       String?                   @db.VarChar(2000)
  status      InspectionChecklistStatus @default(DRAFT)
  completedAt DateTime?
  items       InspectionItem[]
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  deletedAt   DateTime?

  @@index([propertyId, inspectedAt(sort: Desc)])
}

model InspectionItem {
  id              String               @id @default(uuid())
  checklistId     String
  checklist       InspectionChecklist  @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  sector          PropertySector
  name            String               @db.VarChar(200)
  description     String?              @db.VarChar(2000)
  status          InspectionItemStatus @default(PENDING)
  finding         String?              @db.VarChar(2000)
  photoUrl        String?
  taskId          String?
  task            Task?                @relation(fields: [taskId], references: [id], onDelete: SetNull)
  taskTemplateId  String?
  inspectionGuide String?              @db.Text
  guideImageUrls  String[]             @default([])
  isCustom        Boolean              @default(false)
  order           Int                  @default(0)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?

  @@index([checklistId, sector])
  @@index([checklistId, order])
  @@index([taskTemplateId])
}

// ─── Landing Settings ─────────────────────────────────────

model LandingSettings {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  updatedBy String?
}

// ─── User Milestones / Achievements ──────────────────────

model UserMilestone {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type       String   @db.VarChar(50)
  unlockedAt DateTime @default(now())

  @@unique([userId, type])
  @@index([userId])
}

// ─── Notification Dead-Letter Queue ─────────────────────

/**
 * Failed notification side-effects recorded by NotificationsHandlerService.
 * Retried hourly (up to 3 times) by NotificationRetryService.
 * Entries with retryCount = 3 and resolvedAt = null are permanently failed — inspect manually.
 */
model FailedNotification {
  id          String    @id @default(uuid())
  handler     String    @db.VarChar(100) // NotificationsHandlerService method name
  payload     Json // Original handler payload serialized for replay
  lastError   String    @db.VarChar(1000)
  retryCount  Int       @default(0)
  nextRetryAt DateTime  @default(now())
  resolvedAt  DateTime?
  createdAt   DateTime  @default(now())

  @@index([resolvedAt, retryCount, nextRetryAt])
}

// ─── Weekly Challenges ───────────────────────────────────

model WeeklyChallenge {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  weekStart   DateTime
  type        String    @db.VarChar(50)
  target      Int
  progress    Int       @default(0)
  completed   Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([userId, weekStart])
  @@index([userId, completed])
}

// ─── Referral Program ─────────────────────────────────────

/// Status of a single referral. See ADR-010 for program rules.
/// CONVERTED is the terminal state; when it triggers, the referrer's
/// reward counters (referralCreditMonths, referralCreditAnnualDiagnosis,
/// referralCreditBiannualDiagnosis) are recalculated absolutely — never
/// summed across milestones, always set to the value of the current
/// highest milestone reached.
/// EXPIRED is intentionally NOT modeled until the product adds a
/// caducity window (current program has no expiration).
enum ReferralStatus {
  PENDING
  CONVERTED
}

/// A referral record — one row per referred user, regardless of conversion.
/// NOT soft-deletable: referral history is audit-relevant forever.
/// If a referred user is deleted, referredUserId becomes null but the
/// referredEmail (captured at signup) remains for traceability.
model Referral {
  id             String         @id @default(uuid())
  referrerId     String
  referrer       User           @relation("ReferralsMade", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUserId String?
  referredUser   User?          @relation("ReferralsReceived", fields: [referredUserId], references: [id], onDelete: SetNull)
  referredEmail  String?        @db.VarChar(254) /// Captured at signup for post-deletion traceability.
  status         ReferralStatus @default(PENDING)
  convertedAt    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([referrerId, status])
  @@index([referredUserId])
  @@index([status])
}

/// Sequential certificate counter — single-row table for atomic CERT-NNNN generation.
/// Uses @updatedAt for last-issued tracking. No soft-delete (append-only counter).
model CertificateCounter {
  id         String   @id @default("singleton")
  lastNumber Int      @default(0)
  updatedAt  DateTime @updatedAt
}

/// Registro por emisión de Certificado de Mantenimiento Preventivo. Snapshot
/// inmutable del momento de emisión, usado por el dashboard admin para
/// reporting histórico (certificados/mes, trend anual, correlación con ISV).
///
/// Por qué no solo `CertificateCounter`: el counter garantiza numeración
/// atómica pero no preserva historia — imposible saber "cuántos certificados
/// emitimos en marzo 2026" ni correlacionar con snapshots de ISV.
model CertificateEmission {
  id                String   @id @default(uuid())
  /// Número secuencial asignado (CERT-NNNN) al momento de emitir
  certificateNumber Int      @unique
  propertyId        String
  /// User (admin) que disparó la generación
  issuedBy          String
  issuedAt          DateTime @default(now())
  /// Snapshot del ISV al momento de emisión (score 0-100). Permite auditar
  /// elegibilidad retroactivamente sin depender de ISVSnapshot que puede
  /// cambiar si el scoring algorithm evoluciona.
  healthIndexScore  Int
  /// URL del PDF firmado subido a R2 (opcional — hoy se genera on-demand
  /// client-side, pero cuando exista server-side PDF gen será obligatorio)
  pdfUrl            String?

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId, issuedAt(sort: Desc)])
  @@index([issuedAt])
}

// ─────────────────────────────────────────────────────────────
// Professionals directory (internal admin tool)
// ─────────────────────────────────────────────────────────────

enum ProfessionalSpecialty {
  PLUMBER
  GASFITTER
  ELECTRICIAN
  ARCHITECT_ENGINEER
  MASON
  ROOFER_WATERPROOFER
  HVAC_TECHNICIAN
  PEST_CONTROL
  EXTINGUISHER_SERVICE
  DRAIN_CLEANER
  PAINTER
  CARPENTER
  LANDSCAPER
  SOLAR_SPECIALIST
  WATER_TECHNICIAN
  LOCKSMITH
  GLAZIER
  IRONWORKER
  DRYWALL_INSTALLER
}

enum ProfessionalAvailability {
  AVAILABLE
  BUSY
  UNAVAILABLE
}

enum ProfessionalTier {
  A
  B
  C
  BLOCKED
}

enum ProfessionalAttachmentType {
  MATRICULA
  SEGURO_RC
  DNI
  CERTIFICADO_CURSO
  OTRO
}

enum ProfessionalPaymentStatus {
  PENDING
  PAID
  CANCELED
}

/// Passive entity (no auth). Admin-managed directory of registered professionals
/// that EPDE assigns to service requests. Matrícula (registration) is mandatory
/// at creation time via required attachment of type MATRICULA.
model Professional {
  id       String  @id @default(uuid())
  name     String  @db.VarChar(200)
  email    String  @db.VarChar(254)
  phone    String  @db.VarChar(30)
  photoUrl String?
  bio      String? @db.VarChar(1000)

  registrationNumber String @db.VarChar(50)
  registrationBody   String @db.VarChar(200)

  serviceAreas      String[]
  yearsOfExperience Int?
  hourlyRateMin     Decimal? @db.Decimal(10, 2)
  hourlyRateMax     Decimal? @db.Decimal(10, 2)

  availability   ProfessionalAvailability @default(AVAILABLE)
  availableUntil DateTime?

  tier          ProfessionalTier @default(B)
  blockedReason String?          @db.VarChar(500)

  notes String? @db.VarChar(4000)

  createdBy String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  specialties   ProfessionalSpecialtyAssignment[]
  attachments   ProfessionalAttachment[]
  ratings       ProfessionalRating[]
  timelineNotes ProfessionalTimelineNote[]
  tags          ProfessionalTag[]
  assignments   ServiceRequestAssignment[]
  payments      ProfessionalPayment[]

  @@index([deletedAt])
  @@index([availability, deletedAt])
  @@index([tier, deletedAt])
}

model ProfessionalSpecialtyAssignment {
  id             String                @id @default(uuid())
  professionalId String
  specialty      ProfessionalSpecialty
  isPrimary      Boolean               @default(false)

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, specialty])
  @@index([specialty])
}

model ProfessionalAttachment {
  id             String                     @id @default(uuid())
  professionalId String
  type           ProfessionalAttachmentType
  url            String
  fileName       String                     @db.VarChar(200)
  expiresAt      DateTime?
  verifiedAt     DateTime?
  verifiedBy     String?
  createdAt      DateTime                   @default(now())

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId])
  @@index([expiresAt])
  @@index([type, expiresAt])
}

/// Admin-only ratings. Client comments (from post-SR prompts) live here but never
/// form part of the numeric score — only admin entries do. Bayesian smoothing
/// with prior (m=3.5, C=5) is applied in service layer, not persisted.
model ProfessionalRating {
  id               String  @id @default(uuid())
  professionalId   String
  authorId         String
  serviceRequestId String?

  score       Int
  punctuality Int?
  quality     Int?
  priceValue  Int?

  adminComment  String? @db.VarChar(2000)
  clientComment String? @db.VarChar(2000)

  createdAt DateTime @default(now())

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId])
  @@index([professionalId, createdAt])
}

model ProfessionalTimelineNote {
  id             String   @id @default(uuid())
  professionalId String
  authorId       String
  content        String   @db.VarChar(2000)
  createdAt      DateTime @default(now())

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@index([professionalId, createdAt])
}

model ProfessionalTag {
  id             String @id @default(uuid())
  professionalId String
  tag            String @db.VarChar(50)

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, tag])
  @@index([tag])
}

/// 1:1 between ServiceRequest and assigned Professional.
/// If the assigned Professional is later blocked, existing assignments stay
/// (admin must close/reassign manually), but no new ones can be created.
model ServiceRequestAssignment {
  id               String   @id @default(uuid())
  serviceRequestId String   @unique
  professionalId   String
  assignedAt       DateTime @default(now())
  assignedBy       String

  serviceRequest ServiceRequest @relation(fields: [serviceRequestId], references: [id], onDelete: Cascade)
  professional   Professional   @relation(fields: [professionalId], references: [id], onDelete: Restrict)

  @@index([professionalId])
  @@index([professionalId, assignedAt])
}

/// EPDE pays the professional. PENDING is auto-created on SR completion with
/// a linked professional; amount is adjusted by admin before marking PAID.
model ProfessionalPayment {
  id               String                    @id @default(uuid())
  professionalId   String
  serviceRequestId String?
  amount           Decimal                   @db.Decimal(12, 2)
  status           ProfessionalPaymentStatus @default(PENDING)
  paidAt           DateTime?
  paymentMethod    String?                   @db.VarChar(50)
  receiptUrl       String?
  notes            String?                   @db.VarChar(1000)
  createdAt        DateTime                  @default(now())

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Restrict)

  @@index([professionalId, status])
  @@index([status, createdAt])
  @@index([serviceRequestId])
}

// ─────────────────────────────────────────────────────────────
// Technical Inspections — paid professional service (ADR-019)
// ─────────────────────────────────────────────────────────────
//
// Informe profesional firmado por la arquitecta matriculada. Servicio
// distinto del Certificado de Mantenimiento (que es automático e incluido
// en el plan). La inspección técnica es un deliverable manual con peso
// legal — tiene precio y se factura aparte.

enum TechnicalInspectionType {
  BASIC
  STRUCTURAL
  SALE
}

enum TechnicalInspectionStatus {
  REQUESTED
  SCHEDULED
  IN_PROGRESS
  REPORT_READY
  PAID
  CANCELED
}

enum TechnicalInspectionPaymentStatus {
  PENDING
  PAID
  CANCELED
}

enum InspectionPriceTier {
  SMALL
  MEDIUM
  LARGE
}

model TechnicalInspection {
  id               String                    @id @default(uuid())
  /// INSP-YYYY-NNNN — formato humano legible, generado al crear
  inspectionNumber String                    @unique @db.VarChar(20)
  propertyId       String
  requestedBy      String
  type             TechnicalInspectionType
  status           TechnicalInspectionStatus @default(REQUESTED)

  clientNotes  String?   @db.VarChar(2000)
  adminNotes   String?   @db.VarChar(4000)
  scheduledFor DateTime?
  completedAt  DateTime?

  /// URL del PDF firmado (upload del admin tras visita + redacción)
  deliverableUrl      String?
  deliverableFileName String? @db.VarChar(200)

  /// Facturación — precio congelado al crear para evitar cambios post-solicitud
  feeAmount         Decimal                          @db.Decimal(12, 2)
  /// Tier de superficie que definió el precio (snapshot)
  priceTier         InspectionPriceTier              @default(MEDIUM)
  /// Superficie (m²) de la propiedad al momento de solicitar (snapshot)
  propertySqm       Float?
  feeStatus         TechnicalInspectionPaymentStatus @default(PENDING)
  /// true si el cliente tenía plan activo al momento de solicitar (aplica -15%)
  hadActivePlan     Boolean                          @default(false)
  paidAt            DateTime?
  paymentMethod     String?                          @db.VarChar(50)
  paymentReceiptUrl String?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  property  Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  requester User     @relation(fields: [requestedBy], references: [id], onDelete: Restrict)

  @@index([propertyId])
  @@index([requestedBy])
  @@index([status])
  @@index([deletedAt])
  @@index([status, createdAt])
}

/// Counter singleton por año para generar INSP-YYYY-NNNN atómicamente.
/// yearlyCounters: Record<string, number> ej: { "2026": 23, "2027": 0 }
model TechnicalInspectionCounter {
  id             String   @id @default("singleton")
  yearlyCounters Json     @default("{}")
  updatedAt      DateTime @updatedAt
}
